@model CreateEftpsViewModel
@{ ViewData["Title"] = "EFTPS-style ACH payment"; }
<div class="row justify-content-center"><div class="col-lg-7"><div class="mb-4"><div class="eyebrow">CCD+ TAX PAYMENT</div><h1>EFTPS-style tax payment</h1><p class="text-secondary">Creates a simulated CCD credit with an addenda 05 TXP segment. This is not Treasury certification.</p></div>
<form method="post" class="surface form-surface"><div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<div class="mb-3"><label asp-for="OriginatingAccountId" class="form-label">Originating account</label><select asp-for="OriginatingAccountId" asp-items="Model.Accounts" class="form-select"><option value="">Select an account</option></select><span asp-validation-for="OriginatingAccountId" class="text-danger"></span></div>
<div class="row"><div class="col-md-6 mb-3"><label asp-for="CompanyName" class="form-label"></label><input asp-for="CompanyName" class="form-control"><span asp-validation-for="CompanyName" class="text-danger"></span></div><div class="col-md-6 mb-3"><label asp-for="CompanyId" class="form-label"></label><input asp-for="CompanyId" class="form-control"><span asp-validation-for="CompanyId" class="text-danger"></span></div></div>
<div class="mb-3"><label asp-for="TaxpayerIdentificationNumber" class="form-label">TIN</label><input asp-for="TaxpayerIdentificationNumber" class="form-control"><span asp-validation-for="TaxpayerIdentificationNumber" class="text-danger"></span></div>
<div class="row"><div class="col-md-6 mb-3"><label asp-for="TaxTypeCode" class="form-label"></label><input asp-for="TaxTypeCode" class="form-control" placeholder="94105"><span asp-validation-for="TaxTypeCode" class="text-danger"></span></div><div class="col-md-6 mb-3"><label asp-for="TaxPeriodEndDate" class="form-label">Tax period end (YYMMDD)</label><input asp-for="TaxPeriodEndDate" class="form-control" placeholder="260630"><span asp-validation-for="TaxPeriodEndDate" class="text-danger"></span></div></div>
<div class="row"><div class="col-md-6 mb-3"><label asp-for="Amount" class="form-label"></label><input asp-for="Amount" class="form-control"><span asp-validation-for="Amount" class="text-danger"></span></div><div class="col-md-6 mb-3"><label asp-for="SettlementDate" class="form-label"></label><input asp-for="SettlementDate" class="form-control"></div></div>
<div class="mb-4"><label asp-for="Scenario" class="form-label"></label><select asp-for="Scenario" asp-items="Html.GetEnumSelectList<AchProcessingScenario>()" class="form-select"></select></div>
<div class="form-actions"><button class="btn btn-primary">Create tax payment</button><a class="btn btn-light" asp-action="Index">Cancel</a></div></form></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }

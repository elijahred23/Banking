@model AchExceptionIndexViewModel
@{ ViewData["Title"] = "ACH returns and NOCs"; }
<div class="mb-3"><div class="eyebrow">@Model.Bank.Name</div><h1>Returns and notifications of change</h1></div><partial name="_AchNav" />
<h2 class="h4">Returns</h2><div class="surface table-responsive mb-4"><table class="table mb-0"><thead><tr><th>Received</th><th>Entry</th><th>Code</th><th>Reason</th></tr></thead><tbody>@foreach (var item in Model.Returns) { <tr><td>@item.ReceivedDate.ToLocalTime().ToString("g")</td><td>@item.Entry.ReceiverName · @item.Entry.Amount.ToString("C")</td><td><strong class="text-danger">@item.ReturnCode</strong></td><td>@item.Reason</td></tr> } @if (Model.Returns.Count == 0) { <tr><td colspan="4" class="text-secondary text-center py-3">No returns.</td></tr> }</tbody></table></div>
<h2 class="h4">Notifications of change</h2><div class="surface table-responsive"><table class="table mb-0"><thead><tr><th>Received</th><th>Entry</th><th>Code</th><th>Corrected data</th><th>Description</th></tr></thead><tbody>@foreach (var item in Model.Notifications) { <tr><td>@item.ReceivedDate.ToLocalTime().ToString("g")</td><td>@item.Entry.ReceiverName</td><td><strong>@item.ChangeCode</strong></td><td><code>@item.CorrectedData</code></td><td>@item.Description</td></tr> } @if (Model.Notifications.Count == 0) { <tr><td colspan="5" class="text-secondary text-center py-3">No notifications of change.</td></tr> }</tbody></table></div>

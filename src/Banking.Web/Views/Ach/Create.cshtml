@model CreateAchViewModel
@{ ViewData["Title"] = "Create ACH entry"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="mb-4"><div class="eyebrow">ACH ENTRY</div><h1>Create ACH credit or debit</h1><p class="text-secondary">The entry is validated, grouped into a batch, and emitted in a 94-character NACHA file at cutoff.</p></div>
<form method="post" class="surface form-surface">
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<div class="mb-3"><label asp-for="OriginatingAccountId" class="form-label">Originating account</label><select asp-for="OriginatingAccountId" asp-items="Model.Accounts" class="form-select"><option value="">Select an account</option></select><span asp-validation-for="OriginatingAccountId" class="text-danger"></span></div>
<div class="row"><div class="col-md-6 mb-3"><label asp-for="CompanyName" class="form-label"></label><input asp-for="CompanyName" class="form-control"><span asp-validation-for="CompanyName" class="text-danger"></span></div><div class="col-md-6 mb-3"><label asp-for="CompanyId" class="form-label"></label><input asp-for="CompanyId" class="form-control"><span asp-validation-for="CompanyId" class="text-danger"></span></div></div>
<div class="row"><div class="col-md-4 mb-3"><label asp-for="Purpose" class="form-label"></label><select asp-for="Purpose" asp-items="Html.GetEnumSelectList<AchPaymentPurpose>()" class="form-select"></select></div><div class="col-md-4 mb-3"><label asp-for="SecCode" class="form-label">SEC code</label><select asp-for="SecCode" asp-items="Html.GetEnumSelectList<AchStandardEntryClass>()" class="form-select"></select></div><div class="col-md-4 mb-3"><label asp-for="TransactionCode" class="form-label"></label><select asp-for="TransactionCode" asp-items="Html.GetEnumSelectList<AchTransactionCode>()" class="form-select"></select></div></div>
<div class="mb-3"><label asp-for="ReceiverName" class="form-label"></label><input asp-for="ReceiverName" class="form-control"><span asp-validation-for="ReceiverName" class="text-danger"></span></div>
<div class="row"><div class="col-md-6 mb-3"><label asp-for="ReceivingRoutingNumber" class="form-label">Receiver ABA routing number</label><input asp-for="ReceivingRoutingNumber" class="form-control" inputmode="numeric"><span asp-validation-for="ReceivingRoutingNumber" class="text-danger"></span></div><div class="col-md-6 mb-3"><label asp-for="ReceivingAccountNumber" class="form-label"></label><input asp-for="ReceivingAccountNumber" class="form-control"><span asp-validation-for="ReceivingAccountNumber" class="text-danger"></span></div></div>
<div class="row"><div class="col-md-6 mb-3"><label asp-for="Amount" class="form-label"></label><div class="input-group"><span class="input-group-text">$</span><input asp-for="Amount" class="form-control"></div><span asp-validation-for="Amount" class="text-danger"></span></div><div class="col-md-6 mb-3"><label asp-for="EffectiveEntryDate" class="form-label"></label><input asp-for="EffectiveEntryDate" class="form-control"><span asp-validation-for="EffectiveEntryDate" class="text-danger"></span></div></div>
<div class="row"><div class="col-md-6 mb-3"><label asp-for="EntryDescription" class="form-label"></label><input asp-for="EntryDescription" class="form-control"><span asp-validation-for="EntryDescription" class="text-danger"></span></div><div class="col-md-6 mb-3"><label asp-for="Scenario" class="form-label">Learning scenario</label><select asp-for="Scenario" asp-items="Html.GetEnumSelectList<AchProcessingScenario>()" class="form-select"></select></div></div>
<div class="mb-4"><label asp-for="Addenda05" class="form-label">Addenda 05 (optional)</label><textarea asp-for="Addenda05" class="form-control" rows="2"></textarea><span asp-validation-for="Addenda05" class="text-danger"></span></div>
<div class="d-flex gap-2"><button class="btn btn-primary">Queue ACH entry</button><a class="btn btn-light" asp-action="Index">Cancel</a></div>
</form></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }

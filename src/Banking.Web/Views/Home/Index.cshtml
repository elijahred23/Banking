@model DashboardViewModel
@{ ViewData["Title"] = "Overview"; }
<div class="page-heading mb-4">
    <div><div class="eyebrow">CURRENT PERSONA</div><h1 class="mb-1">@Model.Bank.Name</h1><div class="text-secondary">Routing @Model.Bank.RoutingNumber · BIC @Model.Bank.Bic · @Model.Bank.FedParticipantId</div></div>
    <a class="btn btn-primary" asp-controller="Wires" asp-action="Create">Create outgoing payment</a>
</div>
<div class="row g-3 mb-5">
    <div class="col-sm-6 col-lg-4"><div class="metric h-100"><span>Master account</span><strong>@Model.Bank.MasterAccountBalance.ToString("C")</strong><small>Simulated Fed balance</small></div></div>
    <div class="col-sm-6 col-lg-4"><div class="metric h-100"><span>Outgoing payments</span><strong>@Model.OutgoingCount</strong><small>@Model.OutgoingTotal.ToString("C") in recent activity</small></div></div>
    <div class="col-sm-6 col-lg-4"><div class="metric h-100"><span>Incoming payments</span><strong>@Model.IncomingCount</strong><small>For the active persona</small></div></div>
</div>
<div class="d-flex justify-content-between align-items-center mb-3"><h2 class="h4 mb-0">Recent payment activity</h2><a asp-controller="Wires" asp-action="Index">View all</a></div>
<partial name="_WireTable" model="Model.RecentWires" />

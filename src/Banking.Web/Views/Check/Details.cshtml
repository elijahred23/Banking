@model CheckDetailsViewModel
@{ ViewData["Title"] = "Check details"; var item = Model.Deposit; }

<div class="page-heading align-items-start mb-4"><div><div class="eyebrow">CHECK ITEM</div><h1>Check @item.CheckNumber</h1><p class="text-secondary mb-0"><code>@item.CorrelationId</code></p></div><a asp-action="Index" class="btn btn-outline-secondary">Back to checks</a></div>
<section class="surface section mb-4"><h2 class="h5 mb-3">Check details</h2><dl class="row detail-list mb-0">
    <dt class="col-sm-3">Depository bank</dt><dd class="col-sm-9">@item.DepositoryBank.Name</dd>
    <dt class="col-sm-3">Paying bank</dt><dd class="col-sm-9">@(item.PayingBank?.Name ?? "Not resolved")</dd>
    <dt class="col-sm-3">Depositor</dt><dd class="col-sm-9">@item.DepositorName · account @item.DepositingAccount.AccountNumber</dd>
    <dt class="col-sm-3">MICR</dt><dd class="col-sm-9"><code>@item.RawMicrLine</code></dd>
    <dt class="col-sm-3">Amount</dt><dd class="col-sm-9">@item.Amount.ToString("C")</dd>
    <dt class="col-sm-3">Status</dt><dd class="col-sm-9"><strong>@item.Status</strong></dd>
    @if (item.ReturnReason is not null) { <dt class="col-sm-3">Return / rejection</dt><dd class="col-sm-9">@item.ReturnCode @item.ReturnReason</dd> }
</dl></section>

<h2 class="h4 mt-4">Images</h2>
<div class="surface table-responsive"><table class="table mb-0"><thead><tr><th>Side</th><th>File</th><th>Format</th><th>Bytes</th><th>SHA-256</th></tr></thead><tbody>
@foreach (var image in item.Images.OrderBy(x => x.Side)) { <tr><td>@image.Side</td><td>@image.FileName</td><td>@image.ContentType</td><td>@image.SizeBytes</td><td><code class="small">@image.Sha256Hash</code></td></tr> }
</tbody></table></div>

<h2 class="h4 mt-4">Event timeline</h2>
<ol class="surface list-group list-group-numbered mb-4 overflow-hidden">@foreach (var evt in item.Events.OrderBy(x => x.CreatedDate)) { <li class="list-group-item border-start-0 border-end-0"><strong>@evt.EventType</strong> · @evt.CreatedDate.LocalDateTime.ToString("g")<br /><span class="text-secondary">@evt.Description</span></li> }</ol>

<h2 class="h4 mt-4">Ledger entries</h2>
<div class="surface table-responsive"><table class="table mb-0"><thead><tr><th>Account</th><th>Description</th><th>Debit</th><th>Credit</th></tr></thead><tbody>
@foreach (var entry in item.LedgerEntries.OrderBy(x => x.CreatedDate)) { <tr><td><code>@entry.AccountCode</code><br />@entry.AccountName</td><td>@entry.Description</td><td>@(entry.Debit == 0 ? "" : entry.Debit.ToString("C"))</td><td>@(entry.Credit == 0 ? "" : entry.Credit.ToString("C"))</td></tr> }
@if (item.LedgerEntries.Count == 0) { <tr><td colspan="4" class="text-secondary">No posting entries yet.</td></tr> }
</tbody></table></div>

<h2 class="h4 mt-4">Image cash letter payload</h2>
@if (item.ImageCashLetterPayload is null) { <div class="surface section text-secondary">Not created yet.</div> }
else { <pre class="payload-viewer">@item.ImageCashLetterPayload</pre> }

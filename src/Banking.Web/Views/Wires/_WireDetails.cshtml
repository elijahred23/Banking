@model WireDetailsViewModel
@{
    var wire = Model.Wire;
    var paymentMessageType = wire.TransferType == WireTransferType.FinancialInstitutionCreditTransfer
        ? "pacs.009" : "pacs.008";
}
<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <div class="eyebrow">@wire.Direction @wire.Rail · @paymentMessageType</div>
        <h1>@wire.Amount.ToString("C")</h1>
        <div class="text-secondary">@wire.SenderName → @wire.ReceiverName</div>
    </div>
    <span class="status status-@wire.Status.ToString().ToLowerInvariant() status-large">@wire.Status</span>
</div>

<div class="row g-4">
    <div class="col-xl-7">
        @if (Model.Route is { } route)
        {
            var orderedSteps = route.Steps.OrderBy(x => x.StepNumber).ToList();
            <section class="surface section mb-4">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div><h2 class="h5 mb-1">Correspondent route</h2><div class="section-help">The selected path for this USD SWIFT payment.</div></div>
                    <span class="route-status route-@route.RouteStatus.ToLowerInvariant()">@route.RouteStatus</span>
                </div>
                <div class="route-map" aria-label="Correspondent bank route">
                    @if (orderedSteps.Any())
                    {
                        <span class="route-bank">@orderedSteps[0].FromBank.Name</span>
                        @foreach (var step in orderedSteps)
                        {
                            <span class="route-arrow" aria-hidden="true">→</span>
                            <span class="route-bank">@step.ToBank.Name</span>
                        }
                    }
                </div>
                <div class="route-steps mt-3">
                    @foreach (var step in orderedSteps)
                    {
                        <div class="route-step-row">
                            <div><strong>Step @step.StepNumber</strong> · @step.FromBank.Name → @step.ToBank.Name</div>
                            <div class="route-step-meta"><span>@step.StepType</span><span class="delivery-status delivery-@step.Status.ToLowerInvariant()">@step.Status</span></div>
                            @if (!string.IsNullOrWhiteSpace(step.MessageId))
                            { <small>Message <code>@step.MessageId</code> · UETR <code>@step.Uetr</code></small> }
                        </div>
                    }
                </div>
            </section>
        }
        <section class="surface section mb-4">
            <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
                <div><h2 class="h5 mb-1">Lifecycle</h2><div class="section-help">Every persisted processing stage.</div></div>
                <span class="duration-pill">@FormatDuration(Model.ProcessingDuration) total</span>
            </div>
            <div class="timeline">
                @foreach (var stage in Model.Stages)
                {
                    <div class="timeline-item">
                        <div class="timeline-dot"></div>
                        <div class="timeline-heading">
                            <strong>@stage.Event.EventType</strong>
                            <span class="service-badge">@stage.Service</span>
                        </div>
                        <div>@stage.Event.Description</div>
                        <small>
                            @stage.Event.CreatedDate.ToLocalTime().ToString("MMM d, yyyy · HH:mm:ss.fff")
                            @if (stage.DurationSincePrevious is TimeSpan elapsed)
                            { <span> · +@FormatDuration(elapsed)</span> }
                        </small>
                    </div>
                }
            </div>
        </section>

        <section class="surface section">
            <div class="mb-3"><h2 class="h5 mb-1">Processing observability</h2><div class="section-help">Transport delivery, attempts, timing, and failures.</div></div>
            @if (Model.Deliveries.Any())
            {
                <div class="table-responsive">
                    <table class="table diagnostics-table mb-0">
                        <thead><tr><th>Destination</th><th>Status</th><th>Attempts</th><th>Last update</th></tr></thead>
                        <tbody>
                        @foreach (var delivery in Model.Deliveries)
                        {
                            <tr>
                                <td><code>@delivery.Destination</code></td>
                                <td><span class="delivery-status delivery-@delivery.Status.ToString().ToLowerInvariant()">@delivery.Status</span></td>
                                <td>@delivery.Attempts</td>
                                <td>@delivery.UpdatedDate.ToLocalTime().ToString("HH:mm:ss.fff")</td>
                            </tr>
                            @if (!string.IsNullOrWhiteSpace(delivery.LastError))
                            { <tr class="delivery-error"><td colspan="4"><strong>Failure:</strong> @delivery.LastError</td></tr> }
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-secondary mb-0">No transport delivery has been recorded yet.</p>
            }
            @if (Model.FailureReason is not null)
            { <div class="failure-callout mt-3"><strong>Latest failure</strong><span>@Model.FailureReason</span></div> }
        </section>
    </div>

    <div class="col-xl-5">
        @if (Model.CanRequestReturn || Model.CanInvestigate || Model.Cases.Any())
        {
            <section class="surface section mb-4">
                <div class="mb-3">
                    <h2 class="h5 mb-1">Wire servicing</h2>
                    <div class="section-help">Submit a non-value request against the original payment. Return recovery is not assumed until a response and payment return are received.</div>
                </div>
                @if (Model.CanRequestReturn || Model.CanInvestigate)
                {
                    <form asp-controller="Wires" asp-action="OpenCase" method="post" class="mb-4">
                        <input type="hidden" name="id" value="@wire.Id" />
                        <label for="case-reason-@wire.Id" class="form-label">Case reason</label>
                        <textarea id="case-reason-@wire.Id" name="reason" class="form-control mb-2" rows="3" minlength="10" maxlength="500" required placeholder="Explain why the payment should be returned or investigated."></textarea>
                        <div class="d-flex flex-wrap gap-2">
                            @if (Model.CanRequestReturn)
                            {
                                <button class="btn btn-danger" name="type" value="ReturnRequest" onclick="return confirm('Submit this return request? In the standard simulation, available beneficiary funds will be returned immediately.')">Request return</button>
                            }
                            @if (Model.CanInvestigate)
                            {
                                <button class="btn btn-outline-primary" name="type" value="Investigation">Open investigation</button>
                            }
                        </div>
                    </form>
                }
                @if (Model.Cases.Any())
                {
                    <div class="case-list">
                        @foreach (var item in Model.Cases)
                        {
                            <article class="border rounded p-3 mb-2">
                                <div class="d-flex justify-content-between gap-2">
                                    <strong>@(item.Type == WireCaseType.ReturnRequest ? "Return request" : "Investigation")</strong>
                                    <span class="badge text-bg-light">@item.Status</span>
                                </div>
                                <small class="text-secondary">@item.Id.ToString()[..8] · @item.RequestMessageType@(item.ResponseMessageType is null ? "" : $" → {item.ResponseMessageType}") · @item.CreatedDate.ToLocalTime().ToString("g")</small>
                                <div class="mt-2">@item.Reason</div>
                                @if (item.Resolution is not null)
                                { <div class="mt-2 text-secondary"><strong>Resolution:</strong> @item.Resolution</div> }
                            </article>
                        }
                    </div>
                }
            </section>
        }
        <section class="surface section mb-4">
            <h2 class="h5">Identifiers</h2>
            <dl class="detail-grid">
                <dt>Wire ID</dt><dd><code>@wire.Id</code></dd>
                <dt>Correlation</dt><dd><code>@wire.CorrelationId</code></dd>
                @if (wire.TransferType == WireTransferType.FinancialInstitutionCreditTransfer)
                { <dt>Receiving participant</dt><dd><code>@wire.BeneficiaryAccountNumber</code></dd> }
                else
                { <dt>Beneficiary account</dt><dd><code>@wire.BeneficiaryAccountNumber</code></dd> }
                <dt>Scenario</dt><dd>@wire.Scenario</dd>
                <dt>Payment rail</dt><dd>@wire.Rail</dd>
                <dt>Payment type</dt><dd>@paymentMessageType</dd>
                @if (wire.Rail is PaymentRail.FedNow or PaymentRail.SwiftCbprPlus)
                { <dt>Network reference</dt><dd>@(wire.Imad ?? "Pending")</dd> }
                else
                {
                    <dt>IMAD</dt><dd>@(wire.Imad ?? "Pending")</dd>
                    <dt>OMAD</dt><dd>@(wire.Omad ?? "Pending")</dd>
                }
            </dl>
        </section>
    </div>
</div>

<section class="surface section mt-4">
    <div class="mb-3"><h2 class="h5 mb-1">Accounting journal</h2><div class="section-help">Balanced debit and credit entries posted when settlement completes.</div></div>
    @if (Model.LedgerEntries.Any())
    {
        <div class="table-responsive"><table class="table diagnostics-table mb-0">
            <thead><tr><th>Journal</th><th>Account</th><th>Description</th><th class="text-end">Debit</th><th class="text-end">Credit</th></tr></thead>
            <tbody>@foreach (var entry in Model.LedgerEntries) { <tr><td><code>@entry.JournalId.ToString()[..8]</code></td><td>@entry.AccountName<br><code>@entry.AccountCode</code></td><td>@entry.Description</td><td class="text-end">@(entry.Debit == 0 ? "—" : entry.Debit.ToString("C"))</td><td class="text-end">@(entry.Credit == 0 ? "—" : entry.Credit.ToString("C"))</td></tr> }</tbody>
            <tfoot><tr><th colspan="3">Totals</th><th class="text-end">@Model.LedgerEntries.Sum(x => x.Debit).ToString("C")</th><th class="text-end">@Model.LedgerEntries.Sum(x => x.Credit).ToString("C")</th></tr></tfoot>
        </table></div>
    }
    else { <p class="text-secondary mb-0">No journal has posted. Validated outgoing funds remain on hold until final network acceptance.</p> }
</section>

<section class="surface section mt-4">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
        <div><h2 class="h5 mb-1">ISO 20022 messages</h2><div class="section-help">Formatted payloads and structural validation.</div></div>
        @if (Model.Messages.Count > 1)
        { <span class="compare-hint">Side-by-side comparison</span> }
    </div>
    @if (Model.Messages.Any())
    {
        <div class="message-grid @(Model.Messages.Count > 1 ? "message-grid-compare" : "")">
            @foreach (var item in Model.Messages)
            {
                <article class="iso-message" data-message-id="@item.Message.Id" data-message-type="@item.Message.MessageType">
                    <header class="iso-message-header">
                        <div><strong>@item.Message.MessageType</strong><div>@item.Message.Direction · @item.Message.CreatedDate.ToLocalTime().ToString("HH:mm:ss.fff")</div></div>
                        <div class="message-actions">
                            <button type="button" class="btn btn-sm btn-primary preview-xml">Preview</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary copy-xml">Copy</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary download-xml">Download</button>
                        </div>
                    </header>
                    <div class="xml-validation @(item.IsWellFormed && item.HasExpectedNamespace ? "xml-valid" : "xml-warning")">
                        <span aria-hidden="true">@(item.IsWellFormed && item.HasExpectedNamespace ? "✓" : "!")</span>
                        @item.ValidationMessage
                    </div>
                    <pre class="xml-viewer"><code class="language-xml">@item.FormattedXml</code></pre>
                </article>
            }
        </div>
    }
    else
    {
        <p class="text-secondary mb-0">No messages generated yet. This page will update as the wire progresses.</p>
    }
</section>

@functions {
    private static string FormatDuration(TimeSpan value)
    {
        if (value.TotalMinutes >= 1) return $"{(int)value.TotalMinutes}m {value.Seconds}s";
        if (value.TotalSeconds >= 1) return $"{value.TotalSeconds:0.00}s";
        return $"{value.TotalMilliseconds:0}ms";
    }
}

@model WireTransfer
@{ ViewData["Title"] = "Wire details"; }
<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div><div class="eyebrow">@Model.Direction WIRE</div><h1>@Model.Amount.ToString("C")</h1><div class="text-secondary">@Model.SenderName → @Model.ReceiverName</div></div>
    <span class="status status-@Model.Status.ToString().ToLowerInvariant() status-large">@Model.Status</span>
</div>
<div class="row g-4">
    <div class="col-lg-7">
        <section class="surface section"><h2 class="h5 mb-4">Lifecycle</h2><div class="timeline">
            @foreach (var item in Model.Events.OrderBy(x => x.CreatedDate))
            { <div class="timeline-item"><div class="timeline-dot"></div><div><strong>@item.EventType</strong><div>@item.Description</div><small>@item.CreatedDate.ToLocalTime().ToString("MMM d, yyyy · HH:mm:ss")</small></div></div> }
        </div></section>
    </div>
    <div class="col-lg-5">
        <section class="surface section mb-4"><h2 class="h5">Identifiers</h2><dl class="detail-grid"><dt>Wire ID</dt><dd><code>@Model.Id</code></dd><dt>Correlation</dt><dd><code>@Model.CorrelationId</code></dd><dt>IMAD</dt><dd>@(Model.Imad ?? "Pending")</dd><dt>OMAD</dt><dd>@(Model.Omad ?? "Pending")</dd></dl></section>
        <section class="surface section"><h2 class="h5 mb-3">ISO 20022 messages</h2>
            @foreach (var msg in Model.IsoMessages.OrderBy(x => x.CreatedDate))
            { <details class="message"><summary><strong>@msg.MessageType</strong><span>@msg.Direction · @msg.CreatedDate.ToLocalTime().ToString("HH:mm:ss")</span></summary><pre><code>@msg.XmlPayload</code></pre></details> }
            @if (!Model.IsoMessages.Any()) { <p class="text-secondary mb-0">No messages generated yet. Refresh as the wire progresses.</p> }
        </section>
    </div>
</div>

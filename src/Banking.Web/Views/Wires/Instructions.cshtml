@model WireInstructionsViewModel
@{
    ViewData["Title"] = "Wire instructions";
    var source = Model.SourceAccounts.FirstOrDefault();
}

<div class="instructions-hero mb-4">
    <div>
        <div class="eyebrow">PAYMENT GUIDE</div>
        <h1 class="mb-2">How to create wires and ISO 20022 messages</h1>
        <p class="text-secondary mb-0">Follow these end-to-end steps using the current data for <strong>@Model.Bank.Name</strong>. Accounts, institutions, routing details, servicing cases, and supporting messages are connected to live lab records.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Create a payment</a>
</div>

<nav class="instruction-jump surface mb-4" aria-label="Wire type instructions">
    <span>Jump to</span>
    <a href="#fedwire">Fedwire</a>
    <a href="#fednow">FedNow</a>
    <a href="#swift">SWIFT CBPR+</a>
    <a href="#pacs009">pacs.009</a>
    <a href="#message-workflows">Message workflows</a>
    <a href="#iso-messages">Wire messages</a>
    <a href="#return-request">Return request</a>
    <a href="#investigation">Investigation</a>
</nav>

<section class="surface instruction-source mb-4" aria-labelledby="source-heading">
    <div>
        <div class="eyebrow">STEP ZERO</div>
        <h2 id="source-heading" class="h4 mb-1">Choose a funded source account</h2>
        <p class="section-help mb-0">The selected account must belong to the active bank persona.</p>
    </div>
    @if (Model.SourceAccounts.Count == 0)
    {
        <div class="instruction-empty">No source accounts are available for this bank.</div>
    }
    else
    {
        <div class="account-list">
            @foreach (var account in Model.SourceAccounts)
            {
                <div class="account-option">
                    <span>@account.CustomerName</span>
                    <code>@account.AccountNumber</code>
                    <strong>@account.AvailableBalance.ToString("C") available</strong>
                </div>
            }
        </div>
    }
</section>

<div class="instruction-stack">
    <section id="fedwire" class="surface instruction-card">
        <partial name="_InstructionHeading" model='new WireInstructionHeadingViewModel("Fedwire", "Domestic high-value payment", "Same-country banks", Model.DomesticDestinations.Count > 0)' />
        <ol class="instruction-steps">
            <li><div><strong>Select Fedwire as the payment rail.</strong><span>Use it for a domestic payment to another bank in @Model.Bank.CountryCode.</span></div></li>
            <li><div><strong>Choose the source account.</strong><span>@(source is null ? "A source account must first be added to the database." : $"For example: {source.CustomerName} · {source.AccountNumber}.")</span></div></li>
            <li><div><strong>Select a receiving bank and beneficiary.</strong><span>Copy the beneficiary account exactly from an eligible database record below.</span></div></li>
            <li><div><strong>Enter the USD amount and scenario.</strong><span>Standard completes normally; the other scenarios demonstrate pending, rejection, or malformed-message handling.</span></div></li>
            <li><div><strong>Submit and inspect the wire timeline.</strong><span>The lab creates a funds hold, ISO 20022 messages, Fed settlement identifiers, and ledger entries as processing advances.</span></div></li>
        </ol>
        <partial name="_InstructionDestinations" model="Model.DomesticDestinations" />
    </section>

    <section id="fednow" class="surface instruction-card">
        <partial name="_InstructionHeading" model='new WireInstructionHeadingViewModel("FedNow", "Domestic instant payment", "Maximum $10,000,000", Model.Bank.FedNowEnabled && Model.Bank.FedNowSendEnabled && Model.Bank.FedNowOnline && Model.FedNowDestinations.Count > 0)' />
        @if (!Model.Bank.FedNowEnabled || !Model.Bank.FedNowSendEnabled || !Model.Bank.FedNowOnline)
        {
            <div class="alert alert-warning mt-3 mb-0">@Model.Bank.Name is not currently enabled and online to send FedNow payments in the database.</div>
        }
        <ol class="instruction-steps">
            <li><div><strong>Select FedNow as the payment rail.</strong><span>The receiver must be a same-country FedNow participant that is enabled, receive-enabled, and online.</span></div></li>
            <li><div><strong>Choose the source account.</strong><span>Confirm its available balance covers the payment.</span></div></li>
            <li><div><strong>Select an eligible receiver.</strong><span>The list below already applies the current participation and availability flags from the database.</span></div></li>
            <li><div><strong>Enter an amount up to $10 million.</strong><span>Choose a learning scenario, then submit the payment.</span></div></li>
            <li><div><strong>Review instant-payment processing.</strong><span>Watch for receiver acceptance, immediate final settlement, account posting, and completion.</span></div></li>
        </ol>
        <partial name="_InstructionDestinations" model="Model.FedNowDestinations" />
    </section>

    <section id="swift" class="surface instruction-card">
        <partial name="_InstructionHeading" model='new WireInstructionHeadingViewModel("SWIFT CBPR+", "International USD wire", "IBAN and BIC required", Model.Bank.SwiftEnabled && Model.InternationalDestinations.Count > 0)' />
        @if (!Model.Bank.SwiftEnabled)
        {
            <div class="alert alert-warning mt-3 mb-0">@Model.Bank.Name is not currently SWIFT-enabled in the database.</div>
        }
        <ol class="instruction-steps">
            <li><div><strong>Select SWIFT international wire (CBPR+).</strong><span>Use this rail when the receiving bank is outside @Model.Bank.CountryCode.</span></div></li>
            <li><div><strong>Choose the source account and foreign receiving bank.</strong><span>Both sending and receiving institutions must be SWIFT-enabled.</span></div></li>
            <li><div><strong>Enter the beneficiary name and IBAN.</strong><span>Use the exact name and international account number shown below; routing uses the receiving bank's BIC.</span></div></li>
            <li><div><strong>Enter the USD amount and scenario.</strong><span>This learning flow settles in USD and does not perform foreign exchange.</span></div></li>
            <li><div><strong>Submit and follow the serial-method flow.</strong><span>Inspect the CBPR+ pacs.008, status messages, simulated correspondent settlement, and receiving-bank posting.</span></div></li>
        </ol>
        <partial name="_InstructionDestinations" model="Model.InternationalDestinations" />
    </section>

    <section id="pacs009" class="surface instruction-card">
        <partial name="_InstructionHeading" model='new WireInstructionHeadingViewModel("pacs.009", "Financial institution credit transfer", "Fedwire or FedNow", true)' />
        <ol class="instruction-steps">
            <li><div><strong>Select Financial institution credit transfer (pacs.009).</strong><span>This moves the active bank's own settlement liquidity and does not debit a customer account.</span></div></li>
            <li><div><strong>Choose Fedwire or FedNow.</strong><span>The lab does not apply its customer-payment FedNow limit to pacs.009. SWIFT CBPR+ pacs.009 is outside the implemented profile.</span></div></li>
            <li><div><strong>Select the receiving bank.</strong><span>The message identifies both financial institutions by routing number; no beneficiary name or account is required.</span></div></li>
            <li><div><strong>Enter the USD amount and scenario.</strong><span>The sending bank must have enough master-account liquidity to settle the transfer.</span></div></li>
            <li><div><strong>Submit and inspect processing.</strong><span>The lab creates pacs.009.001.08, validates it, settles the banks' master accounts, returns pacs.002 statuses, creates the incoming transfer, and records balanced institution-transfer journals.</span></div></li>
        </ol>
    </section>

    <section id="message-workflows" class="surface instruction-card">
        <partial name="_InstructionHeading" model='new WireInstructionHeadingViewModel("Non-value message workflows", "Create business-led ISO conversations", "No existing wire required", true)' />
        <div class="row g-3 mt-2">
            <div class="col-lg-4"><div class="workflow-guide"><code>pain.013 → admi.007 / pain.014</code><h3 class="h5">Request a payment</h3><p>Select your creditor account, the debtor institution and account, amount, rail, and remittance purpose. The normal path records delivery acknowledgement; the rejection scenario returns pain.014. It does not pretend the request itself moved funds.</p></div></div>
            <div class="col-lg-4"><div class="workflow-guide"><code>camt.060 → camt.052</code><h3 class="h5">Request an account report</h3><p>Choose a balance or activity report for the current business day. The service returns a report using the active bank's actual simulated master-account balance.</p></div></div>
            <div class="col-lg-4"><div class="workflow-guide"><code>admi.004 → admi.011</code><h3 class="h5">Send a participant broadcast</h3><p>Select the receiving FedNow participant, event code, and operational details. The recipient returns a correlated system-event acknowledgement.</p></div></div>
        </div>
        <a class="btn btn-primary mt-3" asp-action="MessageWorkflows">Open non-value workflows</a>
    </section>

    <section id="iso-messages" class="surface instruction-card">
        <partial name="_InstructionHeading" model='new WireInstructionHeadingViewModel("Wire-scoped message workbench", "Create messages about an existing payment", "An existing wire is required", true)' />
        <ol class="instruction-steps">
            <li><div><strong>Create the original wire.</strong><span>Use Customer credit transfer for pacs.008 or Financial institution credit transfer for pacs.009, then submit it over the required rail.</span></div></li>
            <li><div><strong>Open the wire detail page.</strong><span>The original payment supplies the UETR, amount, parties, accounts, institutions, rail endpoints, and business service used by supporting messages.</span></div></li>
            <li><div><strong>Find ISO 20022 messages.</strong><span>Select a payment or servicing message that legitimately references the existing wire, then optionally enter a scenario narrative of up to 500 characters.</span></div></li>
            <li><div><strong>Select Generate.</strong><span>The lab builds a rail-aware business application header and structured payload, applies the correct inbound or outbound direction, validates the result, and saves it against the wire.</span></div></li>
            <li><div><strong>Verify the end-to-end result.</strong><span>Confirm the MessageGenerated lifecycle event, validation result, direction, original UETR correlation, formatted XML preview, copy action, and download action on the same page.</span></div></li>
        </ol>

        <h3 class="h5 mt-4 mb-1">Message-specific creation paths</h3>
        <p class="section-help">Native paths exercise payment or servicing behavior. Workbench paths let you generate the same message directly for learning and inspection.</p>
        <div class="table-responsive mt-3">
            <table class="table diagnostics-table instruction-message-table mb-0">
                <thead><tr><th>Message</th><th>Direction</th><th>How to create it</th><th>End-to-end result</th></tr></thead>
                <tbody>
                    <tr><td><code>pacs.008</code></td><td>Outbound</td><td>Create a Customer credit transfer, or select it in the workbench.</td><td>Validates the customer payment, transmits it, settles it, and creates the receiving wire and postings.</td></tr>
                    <tr><td><code>pacs.009</code></td><td>Outbound</td><td>Create a Financial institution credit transfer, or select it in the workbench.</td><td>Moves bank liquidity through Fedwire or FedNow and records institution settlement journals.</td></tr>
                    <tr><td><code>pacs.004</code></td><td>Inbound</td><td>Request return on a settled outgoing wire, or select it in the workbench.</td><td>Records the returned payment; the native path reverses balances and marks both wires Returned.</td></tr>
                    <tr><td><code>pain.013</code></td><td>Outbound</td><td>Use Request a payment under Non-value message workflows.</td><td>Creates a standalone drawdown request before any resulting payment exists.</td></tr>
                    <tr><td><code>pain.014</code></td><td>Inbound</td><td>Select Simulate rejection on the request-for-payment form.</td><td>Records that the drawdown request was not delivered because of a simulated business error.</td></tr>
                    <tr><td><code>camt.110</code></td><td>Outbound</td><td>Open an investigation on a Fedwire payment, or select it in the workbench.</td><td>Sends the Fedwire investigation with original payment data and records its resolution.</td></tr>
                    <tr><td><code>pacs.028</code></td><td>Outbound</td><td>Open an investigation on a FedNow payment, or select it in the workbench.</td><td>Requests the current payment status and links the resulting status response.</td></tr>
                    <tr><td><code>camt.056</code></td><td>Outbound</td><td>Request return on a settled wire, or select it in the workbench.</td><td>Creates the cancellation request and proceeds through decision and return handling.</td></tr>
                    <tr><td><code>camt.029</code></td><td>Inbound</td><td>Complete a return or investigation case, or select it in the workbench.</td><td>Persists the investigation or cancellation resolution against the wire.</td></tr>
                    <tr><td><code>admi.007</code></td><td>Inbound</td><td>Select Receipt acknowledgement in the workbench.</td><td>Acknowledges receipt using the original wire correlation.</td></tr>
                    <tr><td><code>pacs.002</code></td><td>Inbound</td><td>Process a payment or FedNow investigation, or select it in the workbench.</td><td>Records a validated payment status containing the original message definition and UETR.</td></tr>
                    <tr><td><code>admi.002</code></td><td>Inbound</td><td>Select Message rejection in the workbench.</td><td>Persists a technical or business rejection linked to the original message.</td></tr>
                    <tr><td><code>camt.052</code></td><td>Inbound</td><td>Submit an account report request under Non-value message workflows.</td><td>Returns the requested balance or activity report for the active institution.</td></tr>
                    <tr><td><code>camt.060</code></td><td>Outbound</td><td>Use Request an account report under Non-value message workflows.</td><td>Requests a current-business-day report from the selected rail service.</td></tr>
                    <tr><td><code>admi.004</code></td><td>Outbound</td><td>Use Send a system event under Non-value message workflows.</td><td>Sends a participant broadcast with an event code, recipient, and operational narrative.</td></tr>
                    <tr><td><code>admi.011</code></td><td>Inbound</td><td>Generated as the response to the participant broadcast.</td><td>Records the correlated system-event acknowledgement.</td></tr>
                </tbody>
            </table>
        </div>
    </section>

    <section id="return-request" class="surface instruction-card">
        <partial name="_InstructionHeading" model='new WireInstructionHeadingViewModel("Return request", "Request recovery of a completed payment", "Settled outgoing wires only", true)' />
        <ol class="instruction-steps">
            <li><div><strong>Open a settled outgoing wire.</strong><span>From Outgoing or All wires, select a payment whose status is Settled. Return requests are not available for incoming or unsettled payments.</span></div></li>
            <li><div><strong>Find Wire servicing on the detail page.</strong><span>The Request return button appears when the payment is eligible and no other return request is currently open.</span></div></li>
            <li><div><strong>Enter a case reason.</strong><span>Provide between 10 and 500 characters explaining why the original payment should be returned.</span></div></li>
            <li><div><strong>Select Request return and confirm.</strong><span>The lab sends a camt.056 return request and records the case in the wire lifecycle and ISO 20022 message history.</span></div></li>
            <li><div><strong>Review the response and return result.</strong><span>A camt.029 records the decision. In the standard simulation, sufficient beneficiary and settlement balances produce a pacs.004 return, restore the originating customer's funds, and change the wire status to Returned.</span></div></li>
        </ol>
    </section>

    <section id="investigation" class="surface instruction-card">
        <partial name="_InstructionHeading" model='new WireInstructionHeadingViewModel("Investigation", "Request the status of an outgoing payment", "Network-submitted wires", true)' />
        <ol class="instruction-steps">
            <li><div><strong>Open an outgoing wire that reached the network.</strong><span>An investigation is available after submission for wires in SentToFed, PendingAtFed, Settled, Rejected, or Returned status.</span></div></li>
            <li><div><strong>Find Wire servicing on the detail page.</strong><span>The Open investigation button appears when the payment is eligible and no other investigation is currently open.</span></div></li>
            <li><div><strong>Enter a case reason.</strong><span>Provide between 10 and 500 characters describing the status, delivery, or processing issue to investigate.</span></div></li>
            <li><div><strong>Select Open investigation.</strong><span>FedNow uses a pacs.028 status request, Fedwire uses camt.110, and SWIFT CBPR+ uses camt.027.</span></div></li>
            <li><div><strong>Inspect the resolution.</strong><span>The lab records the response as pacs.002 for FedNow or camt.029 for Fedwire and SWIFT CBPR+, then shows the resolution in the servicing case and message history.</span></div></li>
        </ol>
    </section>
</div>

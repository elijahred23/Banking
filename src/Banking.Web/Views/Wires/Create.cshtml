@model CreateWireViewModel
@{ ViewData["Title"] = "Create wire"; }
<div class="row justify-content-center"><div class="col-lg-7">
    <div class="mb-4"><div class="eyebrow">OUTGOING PAYMENT</div><h1>Create a Fed payment</h1><p class="text-secondary">Choose FedNow for instant 24×7 processing or Fedwire for the wire-transfer lab.</p></div>
    <form method="post" class="surface form-surface">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="mb-3"><label asp-for="Rail" class="form-label">Payment rail</label><select asp-for="Rail" asp-items="Html.GetEnumSelectList<PaymentRail>()" class="form-select"></select><div class="form-text">FedNow customer credit transfers are limited to $10 million in this current lab profile.</div></div>
        <div class="mb-3"><label asp-for="FromAccountId" class="form-label">From account</label><select asp-for="FromAccountId" asp-items="Model.Accounts" class="form-select"><option value="">Select an account</option></select><span asp-validation-for="FromAccountId" class="text-danger"></span></div>
        <div class="mb-3"><label asp-for="ReceiverBankId" class="form-label">Receiving bank</label><select asp-for="ReceiverBankId" asp-items="Model.Banks" class="form-select"><option value="">Select a bank</option></select><span asp-validation-for="ReceiverBankId" class="text-danger"></span></div>
        <div class="mb-3"><label asp-for="ReceiverName" class="form-label">Beneficiary name</label><input asp-for="ReceiverName" class="form-control" placeholder="Mary Jones"><span asp-validation-for="ReceiverName" class="text-danger"></span></div>
        <div class="mb-3"><label asp-for="BeneficiaryAccountNumber" class="form-label">Beneficiary account</label><input asp-for="BeneficiaryAccountNumber" class="form-control" placeholder="654321"><div class="form-text">Seeded examples: Mary Jones 654321, Alice Carter 445566, Robert Lee 778899.</div><span asp-validation-for="BeneficiaryAccountNumber" class="text-danger"></span></div>
        <div class="mb-3"><label asp-for="Amount" class="form-label">Amount (USD)</label><div class="input-group"><span class="input-group-text">$</span><input asp-for="Amount" class="form-control" inputmode="decimal" placeholder="10000.00"></div><span asp-validation-for="Amount" class="text-danger"></span></div>
        <div class="mb-4"><label asp-for="Scenario" class="form-label">Learning scenario</label><select asp-for="Scenario" asp-items="Html.GetEnumSelectList<ProcessingScenario>()" class="form-select"></select><div class="form-text">Pending exercises an intermediate Fed status; rejection releases the funds hold; malformed ISO fails before transmission.</div></div>
        <div class="d-flex gap-2"><button class="btn btn-primary" type="submit">Submit payment</button><a class="btn btn-light" asp-action="Index">Cancel</a></div>
    </form>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
